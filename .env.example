# ============================================================
# Vendor Intelligence POC — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Snowflake Connection
SNOWFLAKE_ACCOUNT=your-account.snowflakecomputing.com
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=LEARNING_DB
SNOWFLAKE_SCHEMA=MART
SNOWFLAKE_ROLE=SYSADMIN

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# App Configuration
APP_TITLE=Vendor Intelligence Assistant
COMPANY_NAME=Your Company Name
GITHUB_REPO_URL=https://github.com/your-username/vendor-intelligence-poc
